<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="34dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/button_back"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:backgroundTint="@color/app_primary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/profile_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/app_text"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/card_background"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/ivProfileAvatar"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="@drawable/avatar_circle_background"
                android:clipToOutline="true"
                android:contentDescription="@string/profile_title"
                android:outlineProvider="background"
                android:padding="18dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_campus_logo" />

            <Button
                android:id="@+id/btnChangePhoto"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:text="@string/button_change_photo"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:backgroundTint="@color/app_secondary" />

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/profile_default_name"
                android:textColor="@color/app_text"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/profile_default_email"
                android:textColor="@color/app_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvProfileRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:background="@drawable/input_background"
                android:text="@string/profile_default_role"
                android:textColor="@color/app_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_section_overview"
                android:textColor="@color/app_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProfileRegisteredCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/profile_registered_events_unavailable"
                android:textColor="@color/app_text"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvProfileMemberSince"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/profile_not_available"
                android:textColor="@color/app_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvProfileLastLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/profile_not_available"
                android:textColor="@color/app_muted"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
