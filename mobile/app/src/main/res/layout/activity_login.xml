<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_background"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginBottom="14dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_campus_logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auth_hero_title"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/auth_hero_login_copy"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp"
                android:textColor="#DCECF4"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_heading"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/app_text"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_subtitle"
                android:textSize="14sp"
                android:textColor="@color/app_muted"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/app_error_bg"
                android:textColor="@color/app_error_text"
                android:padding="12dp"
                android:textSize="13sp"
                android:visibility="gone"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_email"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/app_text"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress"
                android:background="@drawable/input_background"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:textColor="@color/app_text"
                android:textColorHint="@color/app_muted"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_password"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/app_text"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:background="@drawable/input_background"
                android:paddingStart="16dp"
                android:paddingEnd="50dp"
                android:textSize="14sp"
                android:textColor="@color/app_text"
                android:textColorHint="@color/app_muted"
                android:layout_marginBottom="20dp"
                android:drawableEnd="@android:drawable/ic_menu_view"
                android:drawablePadding="12dp" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="@string/button_login"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/app_primary"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvRegisterLink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/link_register"
                android:textSize="14sp"
                android:textColor="@color/app_muted"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/auth_footer_copy"
            android:textSize="12sp"
            android:textColor="@color/app_muted"/>
    </LinearLayout>
</ScrollView>
